# Copy to /etc/llm-wiki/env on the VPS (or .env locally for `npm run dev`)

PORT=8080
HOST=127.0.0.1
NODE_ENV=production
LOG_LEVEL=info

# Vault location and per-vault state.
VAULT_PATH=/srv/llm-wiki/vault
DB_PATH=/srv/llm-wiki/state/jobs.db
INVARIANTS_FILE=/srv/llm-wiki/etc/system-invariants.txt

# Bearer token for the API. Generate with: head -c 32 /dev/urandom | xxd -p -c 64
API_TOKEN=changeme-please-set-a-real-token

# Claude binary + per-job caps.
CLAUDE_BIN=/usr/local/bin/claude
JOB_TIMEOUT_MS=600000
MAX_SOURCE_BYTES=262144
DISALLOWED_TOOLS=WebSearch,WebFetch
